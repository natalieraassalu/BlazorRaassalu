@page "/currencies"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyIndexPage 
    TItem="Currency" 
    PageTitleText="Currencies Page" 
    EntityTitle="Currencies" 
    Items="currencies" 
    BasePath="currencies">
</MyIndexPage>

@code {
    private IQueryable<Currency> currencies = Enumerable.Empty<Currency>().AsQueryable();

    protected override async Task OnInitializedAsync() {
        if (repo is null) return;
        currencies = (await repo.GetAsync()).AsQueryable();
    }

}
