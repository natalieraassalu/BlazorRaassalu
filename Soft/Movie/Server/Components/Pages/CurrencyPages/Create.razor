@page "/currencies/create"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="currency" 
              EntityTitle="Currency" 
              BasePath="/currencies" 
              OnValidSubmit="addCurrency" />

@code {
    [SupplyParameterFromForm] private Currency item { get; set; } = default!;
    protected override void OnInitialized() => item ??= new();

    private async Task add()
    {
        await repo.CreateAsync(item);
        NavigationManager.NavigateTo("/currencies");
    }
}
