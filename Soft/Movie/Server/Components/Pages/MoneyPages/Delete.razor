@page "/monies/delete"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject IMoniesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Money" 
              EntityTitle="Money" 
              Entity="item" 
              BasePath="/monies" 
              OnValidSubmit="delete" />

@code {
    private Money item;

    [SupplyParameterFromQuery] private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        item = await repo.GetAsync(Id);
        if (item is null) NavigationManager.NavigateTo("/monies");
    }

    private async Task delete()
    {
        await repo.DeleteAsync(item.Id);
        NavigationManager.NavigateTo("/monies");
    }
}
