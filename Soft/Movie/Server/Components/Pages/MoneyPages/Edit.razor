@page "/monies/edit"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject IMoniesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage 
    PageTitleText="Edit Money" 
    EntityTitle="Money" 
    Entity="item" 
    BasePath="/monies"
    EntityId="@Id"
    OnValidSubmit="updateMoney" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private Money item { get; set; }
    protected override async Task OnInitializedAsync() {
        item ??= await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
    private async Task update() {
        await repo.UpdateAsync(item!);
        NavigationManager.NavigateTo("/monies");
    }
}