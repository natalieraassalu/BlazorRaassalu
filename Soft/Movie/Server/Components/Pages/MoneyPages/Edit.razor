@page "/money/edit"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject IMoneyRepo repo
@inject NavigationManager NavigationManager

<MyEditPage 
    PageTitleText="Edit Money" 
    EntityTitle="Money" 
    Entity="item" 
    BasePath="/money"
    EntityId="@Id"
    OnValidSubmit="update" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private Money item { get; set; }
    protected override async Task OnInitializedAsync() {
        item ??= await repo.GetAsync(Id);
        if (item is null) NavigationManager.NotFound();
    }
    private async Task update() {
        await repo.UpdateAsync(item!);
        NavigationManager.NavigateTo("/money");
    }
}