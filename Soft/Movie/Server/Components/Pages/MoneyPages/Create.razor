@page "/monies/create"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject IMoniesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="money" 
              EntityTitle="Money" 
              BasePath="/monies" 
              OnValidSubmit="addMoney" />

@code {
    [SupplyParameterFromForm] private Money item { get; set; } = default!;
    protected override void OnInitialized() => item ??= new();

    private async Task add()
    {
        await repo.CreateAsync(item);
        NavigationManager.NavigateTo("/monies");
    }
}
