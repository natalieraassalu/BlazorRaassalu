@page "/money/create"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject IMoneyRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage Entity="item" 
              EntityTitle="Money" 
              BasePath="/money" 
              OnValidSubmit="add" />

@code {
    [SupplyParameterFromForm] private Money item { get; set; } = default!;
    protected override void OnInitialized() => item ??= new();

    private async Task add()
    {
        await repo.CreateAsync(item);
        NavigationManager.NavigateTo("/money");
    }
}
