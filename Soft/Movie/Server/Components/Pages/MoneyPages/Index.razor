@page "/money"
@using Abc.Data
@using Abc.Infra
@attribute [ExcludeFromInteractiveRouting]
@inject IMoneyRepo repo
@inject NavigationManager NavigationManager

<MyIndexPage 
    TItem="Money" 
    PageTitleText="Money Page" 
    EntityTitle="Money" 
    Items="money" 
    BasePath="money">
</MyIndexPage>

@code {
    private IQueryable<Money> money = Enumerable.Empty<Money>().AsQueryable();

    protected override async Task OnInitializedAsync() {
        if (repo is null) return;
        money = (await repo.GetAsync()).AsQueryable();
    }

}