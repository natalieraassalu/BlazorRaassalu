@page "/movies"
@using Abc.Data
@using Abc.Infra
@using Abc.Razor.Pages
@attribute [ExcludeFromInteractiveRouting]
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyIndexPage 
    TItem="Movie" 
    PageTitleText="Movies Page" 
    EntityTitle="Movies" 
    Items="movies" 
    BasePath="movies">
</MyIndexPage>

@code {
    private IQueryable<Movie> movies = Enumerable.Empty<Movie>().AsQueryable();

    protected override async Task OnInitializedAsync() {
        if (repo is null) return;
        movies = (await repo.GetAsync()).AsQueryable();
    }

}