@page "/countries/delete"
@rendermode InteractiveServer
@using Abc.Data
@using Abc.Infra
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete Movie" EntityTitle="Movie" Entity="country" BasePath="/movies" OnValidSubmit="deleteCountry" />
<MyPropertyViewer Label="Id" Value="@country.Id.ToString()" />
<MyPropertyViewer Label="Name" Value="@country.Name" />
<MyPropertyViewer Label="Code" Value="@country.Code" />

@code {
    private Country country;

    [SupplyParameterFromQuery] private Guid Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        country = await repo.GetAsync(Id);
        if (country is null) NavigationManager.NavigateTo("/countries");
        
    }

    private async Task deleteCountry()
    {
        await repo.DeleteAsync(country.Id);
        NavigationManager.NavigateTo("/countries");
    }
}
